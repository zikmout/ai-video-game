# ─────────────────────────────────────────────────────────────────────────────
# Los Asetinos — AI provider API keys
#
# Copy this file to `.env` and fill in the values to enable AI-generated assets.
# The game runs fully WITHOUT any of these keys, using procedural placeholders.
# When a key is present, the matching asset pipeline is activated (see docs/AI_ASSETS.md).
#
# NEVER commit `.env`. It is git-ignored.
# Only VITE_-prefixed vars are exposed to the client bundle; for paid provider
# keys prefer a small server-side proxy (see docs/AI_ASSETS.md) rather than
# shipping secrets to the browser.
# ─────────────────────────────────────────────────────────────────────────────

# 3D model generation (image/prompt -> mesh). e.g. Tripo, Meshy.
AI_MODEL_PROVIDER=
AI_MODEL_API_KEY=

# Texture generation (prompt -> seamless texture). e.g. Nano Banana / image models.
AI_TEXTURE_PROVIDER=
AI_TEXTURE_API_KEY=

# Audio: SFX, music and voices. e.g. ElevenLabs.
AI_AUDIO_PROVIDER=
AI_AUDIO_API_KEY=

# Cinematics (image -> video). e.g. Seedance / video models.
AI_VIDEO_PROVIDER=
AI_VIDEO_API_KEY=
